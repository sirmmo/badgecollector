    "open-badges",
    "certifications",
    "achievements",
    "github",
    "cloudflare-workers"
  ],
  "author": "Marco Montanari",
  "license": "MIT",
  "homepage": "https://badgecollector.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sirmmo/badgecollector.git",
    "directory": "sdk/js"
  },
  "bugs": {
    "url": "https://github.com/sirmmo/badgecollector/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }

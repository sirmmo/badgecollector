{
  "name": "badgecollector",
  "version": "0.1.0",
  "description": "JS/TS client for badgecollector.org — apify badge assignment via GitHub repository_dispatch or the relay Worker.",
  "type": "module",
  "main": "./index.mjs",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "default": "./index.mjs"
    }
  },
  "files": [
